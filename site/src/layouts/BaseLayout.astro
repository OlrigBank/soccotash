---
import SideMenu from '../components/SideMenu.astro';
import '../styles/global.css';

const {
  title = 'Olrig Bank',
  description = 'Guest information and local guide for Olrig Bank.',
  showSidebar = true,
  robots = '',
} = Astro.props;

const pageTitle = title === 'Olrig Bank' ? title : `${title} | Olrig Bank`;
const activePath = Astro.url.pathname;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f3ec" />
    {robots && <meta name="robots" content={robots} />}
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <div class="site-shell mobile-first-shell">
      <header class="site-header">
        <div class="header-inner mobile-first-header-inner">
          <a href="/" class="brand" aria-label="Olrig Bank home">
            <span class="brand-mark" aria-hidden="true">OB</span>
            <span>Olrig Bank</span>
          </a>

          <nav class="top-nav mobile-first-top-nav" aria-label="Main navigation">
            <a href="/book/">Request a stay</a>
            <a href="/listings/">Listings</a>
            <a href="/guest-information/">Guest information</a>
            <a href="/contact/">Contact</a>
            <a href="/local-guide/">Local guide</a>
          </nav>
        </div>
      </header>

      {showSidebar ? (
        <div class="mobile-menu-wrap">
          <details class="mobile-menu">
            <summary>Explore Olrig Bank</summary>
            <SideMenu activePath={activePath} />
          </details>
        </div>
      ) : null}

      <div class:list={['page-grid', showSidebar ? 'has-sidebar' : 'no-sidebar']}>
        {showSidebar ? (
          <div class="desktop-sidebar-wrap">
            <SideMenu activePath={activePath} />
          </div>
        ) : null}

        <main id="main-content" tabindex="-1">
          <slot />
        </main>
      </div>

      <footer class="site-footer">
        <div class="footer-inner">
          <p>© {currentYear} Olrig Bank, Kendal, Cumbria.</p>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  html {
    -webkit-text-size-adjust: 100%;
    text-size-adjust: 100%;
  }

  body {
    min-width: 320px;
    overflow-x: hidden;
  }

  .skip-link {
    position: absolute;
    left: 0.75rem;
    top: 0.75rem;
    z-index: 100;
    transform: translateY(-150%);
    padding: 0.65rem 0.85rem;
    border-radius: 999px;
    background: var(--accent-dark);
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .header-inner,
  .page-grid,
  .footer-inner,
  .mobile-menu-wrap {
    width: min(1180px, calc(100% - 1rem));
    margin-inline: auto;
  }

  .mobile-first-header-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
  }

  .brand {
    min-height: 44px;
  }

  .brand-mark {
    flex: 0 0 auto;
  }

  .mobile-first-top-nav {
    width: 100%;
    display: flex;
    flex-wrap: nowrap;
    justify-content: flex-start;
    gap: 0.5rem;
    overflow-x: auto;
    padding: 0.2rem 0.05rem 0.35rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .mobile-first-top-nav::-webkit-scrollbar {
    display: none;
  }

  .mobile-first-top-nav a {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.55rem 0.75rem;
    border-radius: 999px;
    background: #eadfce;
    color: var(--ink);
    line-height: 1.2;
    text-decoration: none;
  }

  .mobile-first-top-nav a:focus-visible,
  .mobile-first-top-nav a:hover {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .mobile-menu-wrap {
    padding-top: 0.75rem;
  }

  .mobile-menu {
    background: var(--panel-bg);
    border: 1px solid var(--line);
    border-radius: 1rem;
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .mobile-menu > summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 48px;
    padding: 0.75rem 1rem;
    cursor: pointer;
    font-weight: 800;
    list-style: none;
  }

  .mobile-menu > summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu > summary::after {
    content: '▾';
    margin-left: 1rem;
    transition: transform 160ms ease;
  }

  .mobile-menu[open] > summary::after {
    transform: rotate(180deg);
  }

  .mobile-menu .sidebar {
    border: 0;
    border-top: 1px solid var(--line);
    border-radius: 0;
    box-shadow: none;
    background: transparent;
    padding: 0.85rem 1rem 1rem;
  }

  .mobile-menu .sidebar a {
    display: block;
    min-height: 40px;
    padding: 0.45rem 0.5rem;
  }

  .desktop-sidebar-wrap {
    display: none;
  }

  .page-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 1rem 0 2rem;
  }

  main {
    min-width: 0;
    width: 100%;
  }

  .hero {
    padding: clamp(1.25rem, 7vw, 3rem);
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 10vw, 4rem);
    line-height: 1.05;
  }

  .prose {
    padding: clamp(1rem, 5vw, 2rem);
    overflow-wrap: anywhere;
  }

  .grid {
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .card-content {
    padding: clamp(1rem, 4vw, 1.25rem);
  }

  .button {
    min-height: 44px;
    padding: 0.7rem 1rem;
  }

  input,
  select,
  textarea,
  button {
    font: inherit;
  }

  @media (min-width: 480px) {
    .header-inner,
    .page-grid,
    .footer-inner,
    .mobile-menu-wrap {
      width: min(1180px, calc(100% - 1.5rem));
    }
  }

  @media (min-width: 560px) {
    .grid {
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    }
  }

  @media (min-width: 820px) {
    .header-inner,
    .page-grid,
    .footer-inner,
    .mobile-menu-wrap {
      width: min(1180px, calc(100% - 2rem));
    }

    .mobile-first-header-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.85rem 0;
    }

    .mobile-first-top-nav {
      width: auto;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 0.8rem;
      overflow: visible;
      padding: 0;
    }

    .mobile-first-top-nav a {
      min-height: auto;
      padding: 0;
      border-radius: 0.5rem;
      background: transparent;
    }

    .mobile-menu-wrap {
      display: none;
    }

    .desktop-sidebar-wrap {
      display: block;
      min-width: 0;
    }

    .page-grid {
      padding: 2rem 0 3rem;
    }

    .page-grid.has-sidebar {
      grid-template-columns: 260px minmax(0, 1fr);
      gap: 2rem;
    }

    .desktop-sidebar-wrap .sidebar {
      position: sticky;
      top: 5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.001ms !important;
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
    }
  }
</style>
