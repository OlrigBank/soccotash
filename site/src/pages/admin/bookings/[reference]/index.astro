---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import BookingConversation from '../../../../components/BookingConversation.astro';
import { audit, isSameOrigin } from '../../../../lib/admin/auth';
import { getProperties } from '../../../../lib/booking/config';
import {
  createBookingOfferAttempt,
  deleteProvisionalBookingRequest,
  getBookingActivity,
  getBookingOffers,
  getCustomerBookingPageByReference,
  getProvisionalBookingRequest,
  markBookingOfferFailed,
  markBookingOfferSent,
  publishBookingOffer,
  recordBookingActivity,
  updateProvisionalBookingEmail,
  type BookingOfferLine,
} from '../../../../lib/booking/repository';
import {
  createAdministratorBookingMessage,
  getBookingMessagesByReference,
  markBookingMessageNotification,
} from '../../../../lib/booking/messaging';
import { defaultOfferSubject, sendBookingOfferEmail } from '../../../../lib/booking/offer-email';
import { sendBookerMessageEmail } from '../../../../lib/booking/message-email';
import { getEmailConfiguration } from '../../../../lib/email/sender';
import { customerPricingLinesFromUnknown } from '../../../../lib/pricing/display';

export const prerender = false;

const reference = String(Astro.params.reference || '');
if (!/^[0-9a-f-]{36}$/i.test(reference)) return Astro.redirect('/admin/bookings/');
let booking = await getProvisionalBookingRequest(reference);
if (!booking) return new Response('Booking request not found.', { status: 404 });
const propertyName = getProperties().find((property) => property.id === booking?.propertyId)?.name ?? booking.propertyId;
const emailConfiguration = getEmailConfiguration();
const canOffer = booking.status === 'pending' || booking.status === 'offered';
const canDelete = booking.status === 'pending' || booking.status === 'offered';
const money = (pence: number, currency = 'GBP') => new Intl.NumberFormat('en-GB', { style: 'currency', currency }).format(pence / 100);
const dateLabel = (value: string) => new Intl.DateTimeFormat('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' }).format(new Date(`${value}T12:00:00Z`));

function cleanText(value: FormDataEntryValue | null, max: number): string {
  return String(value || '').trim().slice(0, max);
}
function validEmail(value: string): boolean {
  return value.length <= 254 && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
}
function validOptionalEmail(value: string): boolean {
  return value === '' || validEmail(value);
}
function poundsToPence(value: string): number | null {
  const trimmed = value.trim();
  if (!/^-?\d{1,8}(?:\.\d{1,2})?$/.test(trimmed)) return null;
  const negative = trimmed.startsWith('-');
  const unsigned = negative ? trimmed.slice(1) : trimmed;
  const [whole, decimal = ''] = unsigned.split('.');
  const amount = Number(whole) * 100 + Number(decimal.padEnd(2, '0'));
  return negative ? -amount : amount;
}
function pricingLines(value: Record<string, unknown> | null | undefined): BookingOfferLine[] {
  return customerPricingLinesFromUnknown(value).map(({ label, detail, amountPence }) => ({ label, detail, amountPence }));
}

let offers = await getBookingOffers(reference);
let activity = await getBookingActivity(reference);
const priorOffer = offers.find((offer) => offer.customerStatus === 'active' || offer.customerStatus === 'accepted') ?? offers[0];
const initialLines = priorOffer?.lineItems.length
  ? priorOffer.lineItems
  : pricingLines(booking.pricingResult).length
    ? pricingLines(booking.pricingResult)
    : [{ label: 'Accommodation and charges', detail: 'Price agreed during administrative review.', amountPence: booking.guestTotalPence ?? 0 }];
const defaultValidity = new Date(Date.now() + 7 * 86400000).toISOString().slice(0, 10);

let formLines = initialLines;
let offerMessage = priorOffer?.offerMessage ?? `Thank you for your booking request for ${propertyName}. We are pleased to make the following offer.`;
let terms = priorOffer?.terms ?? '';
let validUntil = priorOffer?.validUntil ?? defaultValidity;
let subject = priorOffer?.subject ?? defaultOfferSubject(booking, propertyName);
let contactEmail = booking.email;
let error = '';
let messageError = '';

if (Astro.request.method === 'POST') {
  if (!isSameOrigin(Astro.request)) return new Response('Cross-site form submission forbidden.', { status: 403 });
  const form = await Astro.request.formData();
  const action = cleanText(form.get('action'), 40) || 'publish-offer';

  if (action === 'send-message') {
    const body = cleanText(form.get('messageBody'), 5000);
    const notificationRequested = form.get('sendMessageEmail') === 'yes';
    const notificationAvailable = Boolean(booking.email && validEmail(booking.email) && emailConfiguration.configured);
    if (!body) {
      messageError = 'Write a message before sending.';
    } else {
      const shouldNotify = notificationRequested && notificationAvailable;
      const message = await createAdministratorBookingMessage({
        reference,
        adminUserId: Astro.locals.adminUser!.id,
        adminDisplayName: Astro.locals.adminUser!.displayName || 'Jenna',
        body,
        notificationRequested: shouldNotify,
        notificationRecipient: shouldNotify ? booking.email : null,
      });
      let notificationStatus: 'sent' | 'failed' | 'skipped' = 'skipped';
      if (shouldNotify) {
        try {
          const configuredOrigin = String(process.env.BOOKING_PUBLIC_URL || '').trim();
          const publicOrigin = configuredOrigin || Astro.url.origin;
          if (!booking.customerAccessToken) throw new Error('The Booker booking-page token is missing.');
          const manageUrl = new URL(`/booking/manage/${booking.customerAccessToken}/`, publicOrigin).toString();
          const sent = await sendBookerMessageEmail({
            booking,
            propertyName,
            senderName: Astro.locals.adminUser!.displayName || 'Jenna',
            body,
            manageUrl,
          });
          notificationStatus = 'sent';
          await markBookingMessageNotification({
            messageId: message.id,
            status: 'sent',
            recipient: booking.email,
            messageIdFromProvider: sent.messageId,
          });
        } catch (sendError) {
          notificationStatus = 'failed';
          await markBookingMessageNotification({
            messageId: message.id,
            status: 'failed',
            error: sendError instanceof Error ? sendError.message : String(sendError),
          });
        }
      }
      await recordBookingActivity({
        bookingReference: reference,
        actor: 'administrator',
        eventType: 'administrator_message_sent',
        details: { messageId: message.publicId, notificationRequested, notificationAvailable, notificationStatus },
      });
      await audit(Astro.locals.adminUser!.id, 'booking.message_sent', {
        bookingReference: reference,
        messageId: message.publicId,
        notificationRequested,
        notificationAvailable,
        notificationStatus,
      });
      return Astro.redirect(`/admin/bookings/${reference}/?message=sent&messageEmail=${notificationRequested ? notificationStatus : 'not-requested'}`);
    }
  } else if (action === 'save-contact') {
    contactEmail = cleanText(form.get('contactEmail'), 254).toLowerCase();
    if (!validOptionalEmail(contactEmail)) {
      error = 'Enter a valid Booker email address or leave it blank.';
    } else {
      const previousEmail = booking.email;
      const updated = await updateProvisionalBookingEmail(reference, contactEmail);
      if (!updated) return new Response('Booking request not found.', { status: 404 });
      await audit(Astro.locals.adminUser!.id, 'booking.contact_email_updated', {
        bookingReference: reference,
        previousEmail,
        newEmail: contactEmail,
      });
      return Astro.redirect(`/admin/bookings/${reference}/?contact=1`);
    }
  } else if (action === 'delete-booking') {
    if (!canDelete) {
      error = `A request with status “${booking.status}” cannot be deleted from this screen.`;
    } else if (form.get('confirmDelete') !== 'yes') {
      error = 'Confirm that you understand this will permanently delete the request.';
    } else {
      const deleted = await deleteProvisionalBookingRequest(reference);
      if (!deleted) {
        error = 'The booking request could not be deleted. It may have changed status.';
      } else {
        await audit(Astro.locals.adminUser!.id, 'booking.request_deleted', {
          bookingReference: reference,
          propertyId: booking.propertyId,
          arrival: booking.arrival,
          departure: booking.departure,
          bookerName: booking.name,
          bookerEmail: booking.email,
          previousStatus: booking.status,
        });
        return Astro.redirect('/admin/bookings/?deleted=1');
      }
    }
  } else if (action === 'publish-offer') {
    const labels = form.getAll('lineLabel').map((value) => cleanText(value, 160));
    const details = form.getAll('lineDetail').map((value) => cleanText(value, 500));
    const amounts = form.getAll('lineAmount').map((value) => poundsToPence(String(value)));
    const emailRequested = form.get('sendEmailCopy') === 'yes';
    offerMessage = cleanText(form.get('offerMessage'), 5000);
    terms = cleanText(form.get('terms'), 5000);
    validUntil = cleanText(form.get('validUntil'), 10);
    subject = cleanText(form.get('subject'), 300);
    formLines = labels.map((label, index) => ({ label, detail: details[index] || '', amountPence: amounts[index] ?? 0 }));

    if (!canOffer) error = `A request with status “${booking.status}” cannot be offered.`;
    else if (!subject) error = 'Enter an offer title or email subject.';
    else if (!formLines.length || formLines.length > 40) error = 'The offer must contain between 1 and 40 price lines.';
    else if (formLines.some((line) => !line.label)) error = 'Every price line needs a label.';
    else if (amounts.some((amount) => amount === null)) error = 'Enter each amount in pounds with no more than two decimal places.';
    else if (validUntil && !/^\d{4}-\d{2}-\d{2}$/.test(validUntil)) error = 'Enter a valid offer expiry date.';
    else if (emailRequested && !booking.email) error = 'Add a Booker email address before requesting an email copy.';
    else if (emailRequested && !validEmail(booking.email)) error = 'The saved Booker email address is not valid.';
    else if (emailRequested && !emailConfiguration.configured) error = emailConfiguration.problem || 'Email delivery is not configured.';

    const totalPence = formLines.reduce((sum, line) => sum + line.amountPence, 0);
    if (!error && totalPence < 0) error = 'The bottom-line offer price cannot be negative.';

    if (!error) {
      const attempt = await createBookingOfferAttempt({
        reference,
        adminUserId: Astro.locals.adminUser!.id,
        currency: booking.pricingCurrency || 'GBP',
        lineItems: formLines,
        totalPence,
        offerMessage,
        terms,
        validUntil: validUntil || undefined,
        recipientEmail: booking.email || '',
        subject,
        emailRequested,
      });

      await publishBookingOffer({ offerId: attempt.id, reference });
      await audit(Astro.locals.adminUser!.id, 'booking.offer_published', {
        bookingReference: reference,
        offerReference: attempt.publicId,
        totalPence,
        currency: booking.pricingCurrency || 'GBP',
        emailRequested,
      });

      if (!emailRequested) return Astro.redirect(`/admin/bookings/${reference}/?published=1&email=skipped`);

      try {
        const configuredOrigin = String(process.env.BOOKING_PUBLIC_URL || '').trim();
        const publicOrigin = configuredOrigin || Astro.url.origin;
        if (!booking.customerAccessToken) throw new Error('The Booker booking-page token is missing.');
        const manageUrl = new URL(`/booking/manage/${booking.customerAccessToken}/`, publicOrigin).toString();
        const delivery = await sendBookingOfferEmail({
          booking,
          propertyName,
          currency: booking.pricingCurrency || 'GBP',
          lineItems: formLines,
          totalPence,
          offerMessage,
          terms,
          validUntil: validUntil || null,
          subject,
          manageUrl,
        });
        await markBookingOfferSent({ offerId: attempt.id, reference, deliveryMessageId: delivery.messageId });
        await audit(Astro.locals.adminUser!.id, 'booking.offer_email_sent', {
          bookingReference: reference,
          offerReference: attempt.publicId,
          recipient: booking.email,
          provider: delivery.provider,
        });
        return Astro.redirect(`/admin/bookings/${reference}/?published=1&email=sent`);
      } catch (sendError) {
        await markBookingOfferFailed(attempt.id, sendError);
        await audit(Astro.locals.adminUser!.id, 'booking.offer_email_failed', {
          bookingReference: reference,
          offerReference: attempt.publicId,
          recipient: booking.email,
          error: sendError instanceof Error ? sendError.message : String(sendError),
        });
        return Astro.redirect(`/admin/bookings/${reference}/?published=1&email=failed`);
      }
    }
  } else {
    error = 'Unknown booking action.';
  }

  booking = (await getProvisionalBookingRequest(reference)) ?? booking;
  contactEmail = booking.email;
  offers = await getBookingOffers(reference);
  activity = await getBookingActivity(reference);
}

const recordedLines = pricingLines(booking.pricingResult);
const currency = booking.pricingCurrency || 'GBP';
const showClosedOffers = Astro.url.searchParams.get('showClosedOffers') === '1';
const visibleOffers = showClosedOffers ? offers : offers.filter((offer) => offer.customerStatus !== 'declined' && offer.customerStatus !== 'expired');
const hiddenClosedOfferCount = offers.length - visibleOffers.length;
const published = Astro.url.searchParams.get('published') === '1';
const publishEmailStatus = Astro.url.searchParams.get('email');
const contactSaved = Astro.url.searchParams.get('contact') === '1';
const messageSent = Astro.url.searchParams.get('message') === 'sent';
const messageEmailStatus = Astro.url.searchParams.get('messageEmail');
const notificationAvailable = Boolean(booking.email && validEmail(booking.email) && emailConfiguration.configured);
const messages = await getBookingMessagesByReference(reference, 'administrator', { markRead: true });
const reservationSnapshot = await getCustomerBookingPageByReference(reference);
const reservationVersion = reservationSnapshot
  ? `${reservationSnapshot.bookingStatus}:${reservationSnapshot.customerStatus}:${reservationSnapshot.offerId || ''}:${reservationSnapshot.publishedAt || ''}`
  : booking.status;
let notice = '';
if (messageSent) {
  notice = messageEmailStatus === 'sent'
    ? `The message was sent and an email copy was sent to ${booking.email}.`
    : messageEmailStatus === 'failed'
      ? 'The message was added to the conversation, but the optional email copy failed.'
      : 'The message was added to the conversation.';
} else if (published) {
  notice = publishEmailStatus === 'sent'
    ? `The offer is published and an email copy was sent to ${booking.email}.`
    : publishEmailStatus === 'failed'
      ? 'The offer is published, but the optional email copy could not be sent.'
      : 'The offer is published on the Booker booking page.';
} else if (contactSaved) {
  notice = booking.email ? `The Booker email address was updated to ${booking.email}.` : 'The Booker email address was cleared. Email remains optional.';
}
---
<AdminLayout title={`Messages · ${booking.name}`}>
  <header class="admin-page-header booking-messaging-page-header">
    <div>
      <p class="eyebrow">Booking management</p>
      <p>{propertyName} · {dateLabel(booking.arrival)} to {dateLabel(booking.departure)}</p>
    </div>
    <div class="pricing-header-actions">
      <a class="admin-button" href={`/admin/bookings/${booking.reference}/customer-view/`}>Preview Booker page</a>
      <a class="admin-button admin-button--secondary" href="/admin/bookings/">Back to bookings</a>
    </div>
  </header>

  <BookingConversation
    messages={messages}
    viewer="administrator"
    heading={`Conversation with ${booking.name}`}
    intro={`Messages are sent as ${Astro.locals.adminUser!.displayName || 'Jenna'}. Olrig Bot adds booking-status notices automatically.`}
    pollingUrl={`/api/admin/bookings/${reference}/messages`}
    bookingStatus={booking.status}
    reservationVersion={reservationVersion}
    notificationAvailable={notificationAvailable}
    notificationLabel={`Also email a copy${booking.email ? ` to ${booking.email}` : ''}`}
    messageNotice={notice}
    messageError={messageError}
    reservationButtonLabel="Reservation"
  />

  <div class="booking-drawer-backdrop" data-reservation-backdrop></div>
  <aside class="booking-reservation-drawer booking-reservation-drawer--admin" data-reservation-drawer data-open-on-load={error ? 'yes' : 'no'} aria-hidden="true" aria-label="Reservation and offer controls">
    <header class="booking-reservation-drawer__header">
      <div><p class="eyebrow">Reservation</p><h2>{booking.name}</h2></div>
      <button type="button" class="booking-drawer-close" data-close-reservation-drawer aria-label="Close reservation details">×</button>
    </header>
    <div class="booking-reservation-drawer__body">
      {error && <div class="pricing-message is-error" role="alert">{error}</div>}

      <section class="booking-drawer-section booking-drawer-status">
        <div><h3>{propertyName}</h3><p>{dateLabel(booking.arrival)} to {dateLabel(booking.departure)}</p></div>
        <span class={`status-badge status-${booking.status}`}>{booking.status.replaceAll('_', ' ')}</span>
      </section>

      <section class="booking-drawer-section">
        <p class="eyebrow">Stay details</p>
        <dl class="booking-detail-list">
          <div><dt>Reference</dt><dd><code>{booking.reference}</code></dd></div>
          <div><dt>Booker</dt><dd><strong>{booking.name}</strong></dd></div>
          <div><dt>Contact number</dt><dd>{booking.telephone ? <a href={`tel:${booking.telephone}`}>{booking.telephone}</a> : <span class="muted">None supplied</span>}</dd></div>
          <div><dt>Party</dt><dd>{booking.guests} guest{booking.guests === 1 ? '' : 's'}{booking.pets ? ` · ${booking.pets} pet${booking.pets === 1 ? '' : 's'}` : ''}</dd></div>
          <div><dt>Received</dt><dd>{new Date(booking.createdAt).toLocaleString('en-GB')}</dd></div>
        </dl>
        <form method="post" class="admin-form booking-contact-form">
          <input type="hidden" name="action" value="save-contact" />
          <label>Booker email address
            <input type="email" name="contactEmail" value={contactEmail} maxlength="254" autocomplete="email" />
          </label>
          <div class="booking-contact-form__actions">
            <button class="admin-button admin-button--secondary" type="submit">Save email address</button>
            <small>Used only for optional email copies and notifications.</small>
          </div>
        </form>
      </section>

      <section class="booking-drawer-section">
        <p class="eyebrow">Price breakdown</p>
        <h3>Recorded provisional calculation</h3>
        {recordedLines.length ? <div class="booking-price-table"><table><tbody>
          {recordedLines.map((line) => <tr><td><strong>{line.label}</strong>{line.detail && <small>{line.detail}</small>}</td><td>{money(line.amountPence, currency)}</td></tr>)}
          <tr class="booking-price-total"><th>Recorded provisional total</th><th>{money(booking.guestTotalPence ?? recordedLines.reduce((sum, line) => sum + line.amountPence, 0), currency)}</th></tr>
        </tbody></table></div> : <p class="muted">No published pricing calculation was recorded.</p>}
        {booking.pricingPlanVersion && <p class="pricing-footnote">{booking.pricingPlanName || 'Published pricing plan'} · version {booking.pricingPlanVersion}</p>}
      </section>

      {canOffer ? <section class="booking-drawer-section booking-offer-editor">
        <div class="booking-review-summary__heading">
          <div><p class="eyebrow">Offer controls</p><h3>Publish an offer</h3><p class="admin-panel-intro">The offer message becomes an administrator message in the conversation.</p></div>
          <div class="booking-offer-total"><span>Bottom-line price</span><strong id="offer-total">{money(formLines.reduce((sum, line) => sum + line.amountPence, 0), currency)}</strong></div>
        </div>
        {!emailConfiguration.configured && <div class="pricing-message"><strong>Email delivery is not configured.</strong> The offer can still be published in the conversation. {emailConfiguration.problem}</div>}
        <form method="post" class="admin-form booking-offer-form" id="booking-offer-form" data-currency={currency}>
          <input type="hidden" name="action" value="publish-offer" />
          <label>Offer title / email subject<input type="text" name="subject" value={subject} maxlength="300" required /></label>
          <div class="booking-offer-lines" id="offer-lines">
            {formLines.map((line) => <div class="booking-offer-line">
              <label>Line label<input type="text" name="lineLabel" value={line.label} maxlength="160" required /></label>
              <label>Explanation<input type="text" name="lineDetail" value={line.detail} maxlength="500" /></label>
              <label>Amount (£)<input class="offer-line-amount" type="number" name="lineAmount" value={(line.amountPence / 100).toFixed(2)} step="0.01" required /></label>
              <button class="admin-button admin-button--secondary booking-remove-line" type="button">Remove</button>
            </div>)}
          </div>
          <button class="admin-button admin-button--secondary" id="add-offer-line" type="button">Add price line</button>
          <label>Message from {Astro.locals.adminUser!.displayName || 'Jenna'}<textarea name="offerMessage" rows="5" maxlength="5000">{offerMessage}</textarea></label>
          <label>Offer valid until<input type="date" name="validUntil" value={validUntil} /></label>
          <label>Additional terms<textarea name="terms" rows="4" maxlength="5000">{terms}</textarea></label>
          <div class="booking-send-panel">
            <div>
              <strong>Publish in the Booker conversation</strong>
              <small>The offer and response controls become available immediately.</small>
              <label class="booking-email-copy-option">
                <input type="checkbox" name="sendEmailCopy" value="yes" disabled={!booking.email || !emailConfiguration.configured} />
                <span>Also email a copy{booking.email ? ` to ${booking.email}` : ' (no email address supplied)'}</span>
              </label>
            </div>
            <button class="admin-button" type="submit">Publish offer</button>
          </div>
        </form>
      </section> : <section class="booking-drawer-section">
        <p class="eyebrow">Offer controls</p>
        <h3>{booking.status === 'confirmed' ? 'Confirmed direct booking' : 'Offer closed'}</h3>
        <p>{booking.status === 'confirmed' ? 'The Booker accepted the offer and the booking is confirmed.' : `A new offer cannot be published while the record has status “${booking.status}”.`}</p>
        {priorOffer?.terms && <><h4>Current terms</h4><p class="booking-terms-copy">{priorOffer.terms}</p></>}
      </section>}
    </div>
  </aside>

  <details class="booking-administration" open={showClosedOffers}>
    <summary>Administration and history</summary>
    <div class="booking-administration__body">
      {offers.length > 0 && <section class="admin-panel">
        <div class="booking-review-summary__heading">
          <div><h2>Offer history</h2>{hiddenClosedOfferCount > 0 && !showClosedOffers && <p class="admin-panel-intro">{hiddenClosedOfferCount} declined or expired offer{hiddenClosedOfferCount === 1 ? ' is' : 's are'} hidden.</p>}</div>
          <a class="admin-button admin-button--secondary" href={`/admin/bookings/${booking.reference}/${showClosedOffers ? '' : '?showClosedOffers=1'}`}>
            {showClosedOffers ? 'Hide declined and expired offers' : 'Show declined and expired offers'}
          </a>
        </div>
        {visibleOffers.length ? <div class="admin-table-wrap"><table><thead><tr><th>Created</th><th>Bottom-line price</th><th>Email copy</th><th>Booker response</th><th>Administrator</th></tr></thead><tbody>
          {visibleOffers.map((offer) => <tr><td>{new Date(offer.createdAt).toLocaleString('en-GB')}</td><td><strong>{money(offer.totalPence, offer.currency)}</strong><small>{offer.subject}</small>{offer.recipientEmail && <small>Recipient: {offer.recipientEmail}</small>}</td><td><span class={`status-badge status-${offer.deliveryStatus}`}>{offer.deliveryStatus.replaceAll('_', ' ')}</span>{offer.deliveryError && <small>{offer.deliveryError}</small>}</td><td><span class={`status-badge status-${offer.customerStatus}`}>{offer.customerStatus}</span>{offer.firstViewedAt && <small>First viewed {new Date(offer.firstViewedAt).toLocaleString('en-GB')}</small>}{offer.acceptedAt && <small>Accepted {new Date(offer.acceptedAt).toLocaleString('en-GB')}</small>}{offer.declinedAt && <small>Declined {new Date(offer.declinedAt).toLocaleString('en-GB')}</small>}</td><td>{offer.adminDisplayName || 'Jenna'}</td></tr>)}
        </tbody></table></div> : <p class="muted">All declined and expired offers are hidden.</p>}
      </section>}

      {activity.length > 0 && <section class="admin-panel">
        <h2>Technical booking activity</h2>
        <p class="admin-panel-intro">Technical and audit events remain separate from the Booker conversation.</p>
        <div class="admin-table-wrap"><table><thead><tr><th>Time</th><th>Actor</th><th>Event</th><th>Offer</th></tr></thead><tbody>
          {activity.map((event) => <tr>
            <td>{new Date(event.createdAt).toLocaleString('en-GB')}</td>
            <td><span class={`status-badge status-${event.actor}`}>{event.actor === 'customer' ? 'Booker' : event.actor}</span></td>
            <td>{event.eventType.replaceAll('_', ' ')}</td>
            <td>{event.offerReference ? <code>{event.offerReference}</code> : <span class="muted">—</span>}</td>
          </tr>)}
        </tbody></table></div>
      </section>}

      <section class="admin-panel booking-delete-panel">
        <div>
          <p class="eyebrow">Danger zone</p>
          <h2>Delete booking request</h2>
          <p>{canDelete ? 'Permanently remove this request, its conversation, offer history and provisional calendar block.' : `Requests with status “${booking.status}” cannot be deleted from this screen.`}</p>
        </div>
        <form method="post" class="booking-delete-form" data-confirm-delete>
          <input type="hidden" name="action" value="delete-booking" />
          <label class="booking-delete-confirm">
            <input type="checkbox" name="confirmDelete" value="yes" required disabled={!canDelete} />
            <span>I understand that this permanently deletes the request and conversation.</span>
          </label>
          <button class="admin-button admin-button--danger" type="submit" disabled={!canDelete}>Delete booking request</button>
        </form>
      </section>
    </div>
  </details>
</AdminLayout>

<template id="offer-line-template">
  <div class="booking-offer-line">
    <label>Line label<input type="text" name="lineLabel" maxlength="160" required /></label>
    <label>Explanation<input type="text" name="lineDetail" maxlength="500" /></label>
    <label>Amount (£)<input class="offer-line-amount" type="number" name="lineAmount" value="0.00" step="0.01" required /></label>
    <button class="admin-button admin-button--secondary booking-remove-line" type="button">Remove</button>
  </div>
</template>
<script>
  const lines = document.querySelector('#offer-lines');
  const template = document.querySelector('#offer-line-template');
  const total = document.querySelector('#offer-total');
  const form = document.querySelector('#booking-offer-form');
  const currency = form instanceof HTMLFormElement ? form.dataset.currency || 'GBP' : 'GBP';
  const formatter = new Intl.NumberFormat('en-GB', { style: 'currency', currency });
  function updateTotal() {
    if (!(lines instanceof HTMLElement) || !(total instanceof HTMLElement)) return;
    const amount = Array.from(lines.querySelectorAll('.offer-line-amount')).reduce((sum, input) => {
      return sum + (input instanceof HTMLInputElement && Number.isFinite(input.valueAsNumber) ? input.valueAsNumber : 0);
    }, 0);
    total.textContent = formatter.format(amount);
  }
  function bindRemove(button: Element) {
    button.addEventListener('click', () => {
      if (!(lines instanceof HTMLElement)) return;
      if (lines.children.length <= 1) return;
      button.closest('.booking-offer-line')?.remove();
      updateTotal();
    });
  }
  document.querySelectorAll('.booking-remove-line').forEach((button) => bindRemove(button));
  lines?.addEventListener('input', updateTotal);
  document.querySelector('[data-confirm-delete]')?.addEventListener('submit', (event) => {
    if (!window.confirm('Permanently delete this booking request, conversation and offer history?')) event.preventDefault();
  });
  document.querySelector('#add-offer-line')?.addEventListener('click', () => {
    if (!(lines instanceof HTMLElement) || !(template instanceof HTMLTemplateElement)) return;
    const node = template.content.firstElementChild?.cloneNode(true);
    if (!(node instanceof HTMLElement)) return;
    lines.append(node);
    const remove = node.querySelector('.booking-remove-line');
    if (remove instanceof HTMLButtonElement) bindRemove(remove);
    node.querySelector('input')?.focus();
    updateTotal();
  });
</script>
