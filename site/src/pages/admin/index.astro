---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { PAGES_CMS_SECTIONS } from '../../lib/admin/pages-cms';
import { getPool } from '../../lib/booking/db';
import { countPricingPlans } from '../../lib/pricing/repository';

export const prerender = false;

const [listingCount, bookingCount, syncRows, pricingPlanCount] = await Promise.all([
  Promise.resolve(3),
  getPool().query("SELECT count(*)::int AS count FROM provisional_bookings WHERE status = 'pending'"),
  getPool().query(
    'SELECT property_id, last_success_at, last_error FROM calendar_sync_status ORDER BY property_id',
  ),
  countPricingPlans(),
]);
---
<AdminLayout title="Dashboard">
  <header class="admin-page-header">
    <div>
      <p class="eyebrow">Administration</p>
      <h1>Dashboard</h1>
      <p>Operational overview for Olrig Bank.</p>
    </div>
  </header>

  <section class="admin-card-grid" aria-label="Administration sections">
    <a class="admin-summary-card" href="/admin/content/">
      <span>Website content</span>
      <strong>{PAGES_CMS_SECTIONS.length}</strong>
      <small>Pages CMS sections</small>
    </a>
    <a class="admin-summary-card" href="/admin/listings/">
      <span>Listings</span>
      <strong>{listingCount}</strong>
      <small>configured listings</small>
    </a>
    <a class="admin-summary-card" href="/admin/calendars/">
      <span>Calendar synchronisation</span>
      <strong>{syncRows.rowCount || 0}</strong>
      <small>calendar records</small>
    </a>
    <a class="admin-summary-card" href="/admin/bookings/">
      <span>Booking requests</span>
      <strong>{bookingCount.rows[0].count}</strong>
      <small>awaiting review</small>
    </a>
    <a class="admin-summary-card" href="/admin/pricing/">
      <span>Pricing</span>
      <strong>{pricingPlanCount}</strong>
      <small>versioned pricing plans</small>
    </a>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-heading">
      <div>
        <h2>Calendar status</h2>
        <p>Download the latest Airbnb calendar exports and replace the imported Airbnb availability blocks.</p>
      </div>
      <button class="admin-button" id="calendar-sync-button" type="button">
        Refresh Airbnb calendars
      </button>
    </div>

    <div class="admin-alert admin-alert--info admin-sync-feedback" id="calendar-sync-feedback" role="status" aria-live="polite" hidden></div>

    {syncRows.rowCount ? (
      <div class="admin-table-wrap">
        <table>
          <thead>
            <tr>
              <th>Property</th>
              <th>Last successful sync</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {syncRows.rows.map((row) => (
              <tr>
                <td>{row.property_id}</td>
                <td>
                  {row.last_success_at
                    ? new Date(row.last_success_at).toLocaleString('en-GB')
                    : 'Not yet synced'}
                </td>
                <td>{row.last_error ? 'Error' : 'Ready'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <p>No calendar synchronisation has run yet.</p>
    )}
  </section>

  <script>
    type CalendarSyncResult = {
      propertyId: string;
      ok: boolean;
      feeds?: number;
      imported?: number;
      error?: string;
    };

    type CalendarSyncPayload = {
      error?: string;
      results?: CalendarSyncResult[];
    };

    const syncButton = document.querySelector<HTMLButtonElement>('#calendar-sync-button');
    const syncFeedback = document.querySelector<HTMLDivElement>('#calendar-sync-feedback');

    function showSyncFeedback(message: string, state: 'info' | 'success' | 'error') {
      if (!syncFeedback) return;
      syncFeedback.hidden = false;
      syncFeedback.classList.remove('admin-alert--info', 'admin-alert--success');
      if (state === 'error') {
        syncFeedback.classList.add('admin-alert');
      } else {
        syncFeedback.classList.add(`admin-alert--${state}`);
      }
      syncFeedback.textContent = message;
    }

    syncButton?.addEventListener('click', async () => {
      syncButton.disabled = true;
      syncButton.setAttribute('aria-busy', 'true');
      showSyncFeedback('Downloading the Airbnb exports and updating the calendars…', 'info');

      try {
        const response = await fetch('/api/admin/sync-calendars/', {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            accept: 'application/json',
            'content-type': 'application/json',
          },
          body: '{}',
        });
        const payload = await response.json().catch(() => null) as CalendarSyncPayload | null;

        if (!response.ok) {
          throw new Error(payload?.error || 'Calendar synchronisation failed.');
        }

        const results: CalendarSyncResult[] = Array.isArray(payload?.results) ? payload.results : [];
        const successful = results.filter((result) => result.ok);
        const failed = results.filter((result) => !result.ok);
        const summary = successful.map((result) => {
          const feedLabel = result.feeds === 1 ? 'feed' : 'feeds';
          const blockLabel = result.imported === 1 ? 'block' : 'blocks';
          return `${result.propertyId}: ${result.imported ?? 0} ${blockLabel} from ${result.feeds ?? 0} ${feedLabel}`;
        });

        if (failed.length) {
          const failures = failed.map((result) => `${result.propertyId}: ${result.error || 'unknown error'}`);
          showSyncFeedback(
            `Calendar refresh completed with errors. ${[...summary, ...failures].join('; ')}`,
            'error',
          );
        } else {
          showSyncFeedback(
            `Calendar refresh completed. ${summary.join('; ')}. Reloading the status display…`,
            'success',
          );
          window.setTimeout(() => window.location.reload(), 700);
        }
      } catch (error) {
        showSyncFeedback(
          error instanceof Error ? error.message : 'Calendar synchronisation failed.',
          'error',
        );
      } finally {
        syncButton.disabled = false;
        syncButton.removeAttribute('aria-busy');
      }
    });
  </script>
</AdminLayout>
