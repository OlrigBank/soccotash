---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CustomerBookingView from '../../../../components/CustomerBookingView.astro';
import { getProperties } from '../../../../lib/booking/config';
import {
  getCustomerBookingOffer,
  recordBookingActivity,
  respondToCustomerBookingOffer,
  type CustomerOfferResponseResult,
} from '../../../../lib/booking/repository';
import {
  sendCustomerOfferResponseEmail,
  sendManagementOfferResponseEmail,
} from '../../../../lib/booking/offer-email';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-store, private');
Astro.response.headers.set('Referrer-Policy', 'no-referrer');
Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow, noarchive');
Astro.response.headers.set('X-Soccotash-Booking-UI', '31');

const token = String(Astro.params.token || '');
if (!/^[A-Za-z0-9_-]{43,128}$/.test(token)) return new Response('Booking offer not found.', { status: 404 });

let offer = await getCustomerBookingOffer(token, true);
if (!offer) return new Response('Booking offer not found.', { status: 404 });

const propertyName = getProperties().find((property) => property.id === offer?.propertyId)?.name ?? offer.propertyId;
const configuredOrigin = String(process.env.BOOKING_PUBLIC_URL || '').trim();
const publicOrigin = configuredOrigin || Astro.url.origin;
const manageUrl = new URL(`/booking/manage/${token}/`, publicOrigin).toString();

let responseError = '';
let responseResult: CustomerOfferResponseResult | null = null;

if (Astro.request.method === 'POST') {
  // This route is authorised by the unguessable booking token in the URL.
  // Avoid a separate origin test because reverse proxies can reject legitimate
  // submissions even though the bearer token remains the authorisation check.
  const form = await Astro.request.formData();
  const action = String(form.get('action') || '');
  const confirmed = action === 'accept'
    ? form.get('confirmAccept') === 'yes'
    : action === 'decline'
      ? form.get('confirmDecline') === 'yes'
      : false;

  if (action !== 'accept' && action !== 'decline') {
    responseError = 'The requested booking action was not recognised.';
  } else if (!confirmed) {
    responseError = action === 'accept'
      ? 'Please tick the confirmation box before accepting the offer.'
      : 'Please tick the confirmation box before declining the offer.';
  } else {
    responseResult = await respondToCustomerBookingOffer(token, action);
    if (responseResult === 'accepted' || responseResult === 'declined') {
      offer = await getCustomerBookingOffer(token, false);
      if (!offer) return new Response('Booking offer not found.', { status: 404 });
      const response = responseResult;
      let customerEmailStatus: 'sent' | 'failed' = 'failed';

      try {
        const sent = await sendCustomerOfferResponseEmail({ offer, propertyName, response, manageUrl });
        customerEmailStatus = 'sent';
        await recordBookingActivity({
          bookingReference: offer.bookingReference,
          offerId: offer.offerId,
          actor: 'system',
          eventType: response === 'accepted' ? 'booking_confirmation_email_sent' : 'customer_response_email_sent',
          details: { response, provider: sent.provider, messageId: sent.messageId },
        });
      } catch (error) {
        await recordBookingActivity({
          bookingReference: offer.bookingReference,
          offerId: offer.offerId,
          actor: 'system',
          eventType: response === 'accepted' ? 'booking_confirmation_email_failed' : 'customer_response_email_failed',
          details: { response, error: error instanceof Error ? error.message : String(error) },
        });
      }

      try {
        const adminUrl = new URL(`/admin/bookings/${offer.bookingReference}/`, publicOrigin).toString();
        const sent = await sendManagementOfferResponseEmail({ offer, propertyName, response, adminUrl });
        await recordBookingActivity({
          bookingReference: offer.bookingReference,
          offerId: offer.offerId,
          actor: 'system',
          eventType: sent ? 'management_response_email_sent' : 'management_response_email_skipped',
          details: sent ? { response, provider: sent.provider, messageId: sent.messageId } : { response, reason: 'No management recipient configured.' },
        });
      } catch (error) {
        await recordBookingActivity({
          bookingReference: offer.bookingReference,
          offerId: offer.offerId,
          actor: 'system',
          eventType: 'management_response_email_failed',
          details: { response, error: error instanceof Error ? error.message : String(error) },
        });
      }

      return Astro.redirect(`/booking/manage/${token}/?response=${response === 'accepted' ? 'confirmed' : 'declined'}&email=${customerEmailStatus}`);
    }

    const messages: Record<CustomerOfferResponseResult, string> = {
      accepted: '',
      declined: '',
      already_accepted: 'This booking has already been confirmed.',
      already_declined: 'This offer has already been declined.',
      expired: 'This offer has expired and can no longer be accepted or declined online.',
      superseded: 'This offer link has been replaced by a newer offer. Please use the most recent email from Olrig Bank.',
      dates_unavailable: 'The dates are no longer available. Your response was not recorded; please contact Olrig Bank.',
      not_found: 'This booking offer could not be found.',
    };
    responseError = messages[responseResult];
    offer = await getCustomerBookingOffer(token, false) ?? offer;
  }
}

const responseNotice = Astro.url.searchParams.get('response');
const emailStatus = Astro.url.searchParams.get('email') === 'failed' ? 'failed' : Astro.url.searchParams.get('email') === 'sent' ? 'sent' : null;
const confirmedBooking = offer.bookingStatus === 'confirmed' || offer.bookingStatus === 'approved';
---
<BaseLayout
  title={`${confirmedBooking ? 'Confirmed booking' : 'Booking offer'} · ${propertyName}`}
  description={confirmedBooking ? 'View your confirmed Olrig Bank booking.' : 'Review and respond to your Olrig Bank booking offer.'}
  showSidebar={false}
  robots="noindex,nofollow,noarchive"
>
  <CustomerBookingView
    offer={offer}
    propertyName={propertyName}
    responseNotice={responseNotice}
    responseError={responseError}
    emailStatus={emailStatus}
    allowResponse={true}
  />
</BaseLayout>
