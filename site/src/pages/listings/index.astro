---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingCard from '../../components/ListingCard.astro';

const listings = (await getCollection('listings')).sort((a, b) => {
  const featuredDifference = Number(b.data.featured) - Number(a.data.featured);
  return featuredDifference || a.data.sortOrder - b.data.sortOrder || a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout title="Places to stay" description="Olrig Bank accommodation options in Kendal.">
  <section class="hero">
    <h1>Places to stay</h1>
    <p>Choose the Main House, the Cottage or enquire about using the whole property for a larger group.</p>
  </section>

  <div class="grid">
    {listings.map((entry) => <ListingCard entry={entry} />)}
  </div>
</BaseLayout>
