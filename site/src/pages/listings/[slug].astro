---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Space from '../../components/Space.astro';

export async function getStaticPaths() {
  const listings = await getCollection('listings');
  return listings.map((entry) => ({
    params: { slug: entry.data.slug || entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const allSpaces = await getCollection('spaces');
const spacesBySlug = new Map(allSpaces.map((space) => [space.data.slug, space]));
const selectedSpaces: CollectionEntry<'spaces'>[] = [];

for (const slug of entry.data.spaces) {
  const space = spacesBySlug.get(slug);
  if (space) selectedSpaces.push(space);
}

const missingSpaceSlugs = entry.data.spaces.filter((slug) => !spacesBySlug.has(slug));
const listingFacts = [entry.data.sleeps, entry.data.bedrooms, entry.data.bathrooms].filter(Boolean);
const practicalDetails = [
  { title: 'Guest access', text: entry.data.guestAccess },
  { title: 'Shared spaces', text: entry.data.sharedSpaces },
  { title: 'Parking', text: entry.data.parking },
  { title: 'Access information', text: entry.data.accessInformation },
  { title: 'Important notes', text: entry.data.importantNotes },
].filter((item) => item.text);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <section class="hero">
    {entry.data.tagline ? <p class="eyebrow">{entry.data.tagline}</p> : null}
    <h1>{entry.data.title}</h1>
    {entry.data.summary ? <p>{entry.data.summary}</p> : null}
    {listingFacts.length ? <p class="listing-facts">{listingFacts.join(' · ')}</p> : null}
    <div class="button-group">
      <a class="button" href="/contact/">Ask Jenna about availability</a>
      {entry.data.airbnbUrl ? (
        <a class="button button-secondary" href={entry.data.airbnbUrl} target="_blank" rel="noreferrer">View on Airbnb</a>
      ) : (
        <a class="button button-secondary" href="https://wa.me/447907650960">Message on WhatsApp</a>
      )}
    </div>
  </section>

  {entry.data.image ? <img src={entry.data.image} alt={entry.data.title} class="listing-hero-image" /> : null}

  {entry.data.highlights.length ? (
    <section class="listing-section">
      <div class="section-heading">
        <h2>Highlights</h2>
      </div>
      <ul class="highlight-grid">
        {entry.data.highlights.map((highlight) => <li>{highlight}</li>)}
      </ul>
    </section>
  ) : null}

  <section class="prose">
    <Content />
  </section>

  {entry.data.locationSummary ? (
    <section class="prose listing-section">
      <h2>Location</h2>
      <p>{entry.data.locationSummary}</p>
    </section>
  ) : null}

  {practicalDetails.length ? (
    <section class="listing-section">
      <div class="section-heading">
        <h2>Practical information</h2>
      </div>
      <div class="detail-grid">
        {practicalDetails.map((item) => (
          <article class="detail-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>
  ) : null}

  {entry.data.amenities.length ? (
    <section class="prose listing-section">
      <h2>Amenities</h2>
      <ul class="column-list">
        {entry.data.amenities.map((amenity) => <li>{amenity}</li>)}
      </ul>
    </section>
  ) : null}

  {entry.data.houseRules.length ? (
    <section class="prose listing-section">
      <h2>House rules</h2>
      <ul>
        {entry.data.houseRules.map((rule) => <li>{rule}</li>)}
      </ul>
    </section>
  ) : null}

  {selectedSpaces.length ? (
    <section class="spaces-section">
      <div class="section-heading">
        <h2>Inside this stay</h2>
        <p>Rooms and spaces included in this accommodation option.</p>
      </div>
      <div class="space-grid">
        {selectedSpaces.map((space) => <Space space={space} />)}
      </div>
    </section>
  ) : null}

  <section class="prose enquiry-panel">
    <h2>Ask about a stay</h2>
    <p>Tell Jenna your preferred dates, group size and whether you are interested in the Main House, Cottage or the whole property.</p>
    <div class="button-group">
      <a class="button" href="/contact/">Contact Jenna</a>
      <a class="button button-secondary" href="mailto:olrig.bank@gmail.com">Email Olrig Bank</a>
    </div>
  </section>

  {import.meta.env.DEV && missingSpaceSlugs.length ? (
    <section class="prose developer-note">
      <h2>Missing space references</h2>
      <p>The following space slugs do not have matching content: {missingSpaceSlugs.join(', ')}</p>
    </section>
  ) : null}
</BaseLayout>
