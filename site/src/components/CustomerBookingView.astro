---
import BookingConversation from './BookingConversation.astro';
import type { BookingMessage } from '../lib/booking/messaging';
import type { CustomerBookingOffer } from '../lib/booking/repository';

interface Props {
  offer: CustomerBookingOffer;
  messages: BookingMessage[];
  propertyName: string;
  pollingUrl: string;
  responseNotice?: string | null;
  responseError?: string;
  messageNotice?: string;
  messageError?: string;
  allowResponse?: boolean;
  adminPreview?: boolean;
  emailStatus?: 'sent' | 'failed' | 'skipped' | null;
  messageNotificationAvailable?: boolean;
}

const {
  offer,
  messages,
  propertyName,
  pollingUrl,
  responseNotice = null,
  responseError = '',
  messageNotice = '',
  messageError = '',
  allowResponse = true,
  adminPreview = false,
  emailStatus = null,
  messageNotificationAvailable = false,
} = Astro.props;

const money = (pence: number, currency = 'GBP') => new Intl.NumberFormat('en-GB', { style: 'currency', currency }).format(pence / 100);
const dateLabel = (value: string) => new Intl.DateTimeFormat('en-GB', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC',
}).format(new Date(`${value}T12:00:00Z`));

const confirmed = offer.bookingStatus === 'confirmed' || offer.bookingStatus === 'approved';
const paymentPending = offer.bookingStatus === 'payment_pending' || offer.bookingStatus === 'payment_reported';
const requestPending = offer.customerStatus === 'request_pending' || offer.bookingStatus === 'pending';
const isActive = allowResponse && offer.customerStatus === 'active' && offer.bookingStatus === 'offered';
const displayStatus = confirmed ? 'confirmed'
  : paymentPending ? 'payment_pending' : requestPending ? 'pending' : offer.customerStatus;
const statusHeading = confirmed
  ? 'Booking confirmed'
  : paymentPending
    ? 'Deposit payment required'
  : requestPending
    ? 'Booking request received'
    : offer.customerStatus === 'declined'
      ? 'Offer declined'
      : offer.customerStatus === 'expired'
        ? 'Offer expired'
        : offer.customerStatus === 'superseded'
          ? 'Offer replaced'
          : offer.customerStatus === 'cancelled'
            ? 'Booking cancelled'
            : 'Booking offer ready';
const statusMessage = confirmed
  ? 'Your direct booking with Olrig Bank is confirmed. This private page remains the current booking record.'
  : paymentPending
    ? 'You accepted the offer. Pay or report the required deposit below to confirm the booking.'
  : requestPending
    ? 'Your dates are being held provisionally while Jenna and the Olrig Bank team review the request.'
    : offer.customerStatus === 'declined'
      ? 'You declined this offer. Continue the conversation if you would like to discuss another stay.'
      : offer.customerStatus === 'expired'
        ? 'The acceptance period has ended. Send a message if you would like the stay to be reconsidered.'
        : offer.customerStatus === 'superseded'
          ? 'A newer offer replaced this one. Reservation details show the current offer when available.'
          : offer.customerStatus === 'cancelled'
            ? 'This booking has been cancelled. The conversation remains available as a record.'
            : 'Open Reservation details to review the price, terms and response options.';

function responseMessage(): string {
  const accepted = responseNotice === 'accepted' || responseNotice === 'confirmed' || responseNotice === 'payment-required';
  if (accepted) {
    if (emailStatus === 'sent') return 'Your offer is accepted. Deposit payment is now required, and an email copy was sent.';
    if (emailStatus === 'failed') return 'Your offer is accepted and deposit payment is now required. The optional email copy could not be sent.';
    return 'Your offer is accepted. Deposit payment is now required.';
  }
  if (emailStatus === 'sent') return 'Your decision to decline was recorded and an email copy was sent.';
  if (emailStatus === 'failed') return 'Your decision to decline was recorded, although the optional email copy could not be sent.';
  return 'Your decision to decline was recorded.';
}

const conversationNotice = messageNotice || ((responseNotice === 'accepted' || responseNotice === 'confirmed' || responseNotice === 'payment-required' || responseNotice === 'declined') ? responseMessage() : '');
const conversationError = messageError || responseError;
---
<section class="customer-booking-shell">
  {adminPreview && <div class="customer-booking-message is-preview" role="status">
    Administrator preview of the Booker booking page.
    <a href={`/admin/bookings/${offer.bookingReference}/`}>Return to the booking conversation</a>
  </div>}

  <BookingConversation
    messages={messages}
    viewer="booker"
    heading={adminPreview ? `Booker conversation: ${offer.guestName}` : 'Conversation with Olrig Bank'}
    intro={adminPreview ? 'This is how the continuing booking conversation appears to the Booker.' : 'Reply here to Jenna and the Olrig Bank team. New messages are checked automatically.'}
    pollingUrl={pollingUrl}
    bookingStatus={offer.bookingStatus}
    reservationVersion={`${offer.bookingStatus}:${offer.customerStatus}:${offer.offerId || ''}:${offer.publishedAt || ''}`}
    canCompose={!adminPreview}
    notificationAvailable={messageNotificationAvailable}
    notificationLabel="Also notify the Olrig Bank administrators by email"
    messageNotice={conversationNotice}
    messageError={conversationError}
    reservationButtonLabel={confirmed ? 'Reservation' : paymentPending ? 'Payment & reservation' : requestPending ? 'Request details' : 'Offer & reservation'}
  />

  {!adminPreview && <section class="customer-booking-card customer-booking-access-card">
    <div>
      <p class="eyebrow">Your private booking page</p>
      <h2>Save this page address</h2>
      <p>Bookmark this page or keep its address somewhere safe. Messages, offers and later booking changes stay here; email is optional.</p>
      <p class="customer-booking-security-note">Anyone with this link can view and respond to the booking, so do not share it publicly.</p>
    </div>
    <div class="customer-booking-access-actions">
      <button class="customer-booking-submit" type="button" data-copy-booking-link>Copy page address</button>
      <button class="customer-booking-submit customer-booking-refresh" type="button" data-refresh-booking-page>Check for updates</button>
      <span class="customer-booking-copy-status" data-copy-booking-status aria-live="polite"></span>
    </div>
  </section>}


  <div class="booking-drawer-backdrop" data-reservation-backdrop></div>
  <aside class="booking-reservation-drawer" data-reservation-drawer aria-hidden="true" aria-label="Reservation details">
    <header class="booking-reservation-drawer__header">
      <div>
        <p class="eyebrow">Reservation</p>
        <h2>{propertyName}</h2>
      </div>
      <button type="button" class="booking-drawer-close" data-close-reservation-drawer aria-label="Close reservation details">×</button>
    </header>

    <div class="booking-reservation-drawer__body">
      <section class="booking-drawer-section booking-drawer-status">
        <div>
          <h3>{statusHeading}</h3>
          <p>{statusMessage}</p>
        </div>
        <span class={`customer-booking-status status-${displayStatus}`}>{displayStatus.replaceAll('_', ' ')}</span>
      </section>

      <section class="booking-drawer-section">
        <p class="eyebrow">Stay details</p>
        <dl class="customer-booking-details">
          <div><dt>Arrival</dt><dd>{dateLabel(offer.arrival)}</dd></div>
          <div><dt>Departure</dt><dd>{dateLabel(offer.departure)}</dd></div>
          <div><dt>Party</dt><dd>{offer.guests} guest{offer.guests === 1 ? '' : 's'}{offer.pets ? ` · ${offer.pets} pet${offer.pets === 1 ? '' : 's'}` : ''}</dd></div>
          <div><dt>Booker</dt><dd>{offer.guestName}</dd></div>
          <div><dt>Email</dt><dd>{offer.guestEmail || 'Not supplied — email is optional'}</dd></div>
          <div><dt>Telephone</dt><dd>{offer.guestTelephone || 'None supplied'}</dd></div>
          <div><dt>Reference</dt><dd><code>{offer.bookingReference}</code></dd></div>
          <div><dt>Requested</dt><dd>{new Date(offer.requestCreatedAt).toLocaleString('en-GB')}</dd></div>
          {!confirmed && offer.validUntil && <div><dt>Offer valid through</dt><dd>{dateLabel(offer.validUntil)}</dd></div>}
          {confirmed && offer.acceptedAt && <div><dt>Confirmed</dt><dd>{new Date(offer.acceptedAt).toLocaleString('en-GB')}</dd></div>}
        </dl>
      </section>

      <section class="booking-drawer-section">
        <p class="eyebrow">Price breakdown</p>
        <h3>{confirmed ? 'Confirmed price' : paymentPending ? 'Accepted offer' : requestPending ? 'Recorded provisional cost' : 'Current offer'}</h3>
        {offer.priceAvailable ? <div class="customer-booking-price-table">
          {offer.lineItems.map((line) => <div class="customer-booking-price-line">
            <div><strong>{line.label}</strong>{line.detail && <small>{line.detail}</small>}</div>
            <span>{money(line.amountPence, offer.currency)}</span>
          </div>)}
          <div class="customer-booking-price-line is-total"><strong>{requestPending ? 'Provisional total' : 'Total'}</strong><strong>{money(offer.totalPence, offer.currency)}</strong></div>
        </div> : <p>The price has not yet been confirmed. Olrig Bank will add it as part of the offer.</p>}
        {requestPending && <p class="customer-booking-price-note">This calculation was recorded when the request was made and can be revised before an offer is published.</p>}
      </section>

      {offer.terms && <section class="booking-drawer-section customer-booking-copy">
        <p class="eyebrow">Additional terms</p>
        <p>{offer.terms}</p>
      </section>}



      {paymentPending && <section class="booking-drawer-section customer-booking-payment">
        <div>
          <p class="eyebrow">Deposit payment</p>
          <h3>Pay {money(offer.depositPence || Math.max(1, Math.round(offer.totalPence * 0.25)), offer.currency)} to confirm</h3>
          <p>The remaining balance is {money(offer.balanceDuePence || Math.max(0, offer.totalPence - (offer.depositPence || Math.round(offer.totalPence * 0.25))), offer.currency)} and will be payable later through this same booking page.</p>
        </div>
        <div class="customer-booking-payment-options">
          <article class="customer-booking-payment-option is-recommended">
            <span class="customer-booking-payment-badge">Recommended</span>
            <h4>Pay by Bank</h4>
            <p>Lower-cost bank payment through GoCardless. Secure checkout integration will be enabled in a later implementation.</p>
            <button type="button" class="customer-booking-submit" disabled aria-disabled="true">GoCardless coming soon</button>
          </article>
          <article class="customer-booking-payment-option">
            <h4>Pay by card</h4>
            <p>Pay with a debit or credit card through Stripe. Secure checkout integration will be enabled in a later implementation.</p>
            <button type="button" class="customer-booking-submit" disabled aria-disabled="true">Stripe coming soon</button>
          </article>
          <article class="customer-booking-payment-option is-exceptional">
            <h4>Manual bank transfer</h4>
            <p>Use only when agreed with Olrig Bank. Send the deposit using the bank details supplied by Jenna, using booking reference <code>{offer.bookingReference}</code>.</p>
            <form method="post" class="customer-booking-decision-form">
              <input type="hidden" name="action" value="report-bank-transfer" />
              <label class="customer-booking-confirm-check">
                <input type="checkbox" name="confirmTransfer" value="yes" required />
                <span>I confirm that I have sent the deposit by bank transfer.</span>
              </label>
              <button class="customer-booking-submit customer-booking-accept" type="submit">I have sent the bank transfer</button>
            </form>
            <small>This immediately marks the booking confirmed and tells administrators to verify the transfer.</small>
          </article>
        </div>
      </section>}

      {isActive && <section class="booking-drawer-section customer-booking-response">
        <div>
          <p class="eyebrow">Your response</p>
          <h3>Accept or decline this offer</h3>
          <p>Accepting records your agreement to the dates, price and terms. The booking is confirmed after the required deposit is recorded.</p>
        </div>
        <div class="customer-booking-actions">
          <form method="post" class="customer-booking-decision-form">
            <input type="hidden" name="action" value="accept" />
            <strong>Accept offer</strong>
            <p>Confirm that you accept the dates, price and terms shown here.</p>
            <label class="customer-booking-confirm-check">
              <input type="checkbox" name="confirmAccept" value="yes" required />
              <span>I have reviewed and accept the dates, price and terms.</span>
            </label>
            <button class="customer-booking-submit customer-booking-accept" type="submit">Accept offer and continue to payment</button>
          </form>

          <form method="post" class="customer-booking-decision-form is-decline">
            <input type="hidden" name="action" value="decline" />
            <strong>Decline this offer</strong>
            <p>Declining closes this offer. Continue the conversation to discuss a different stay.</p>
            <label class="customer-booking-confirm-check">
              <input type="checkbox" name="confirmDecline" value="yes" required />
              <span>I understand that declining will close this offer.</span>
            </label>
            <button class="customer-booking-submit customer-booking-decline" type="submit">Decline booking offer</button>
          </form>
        </div>
      </section>}

      <p class="customer-booking-help">Use the conversation as the primary contact method for questions, changes and later amendment requests.</p>
    </div>
  </aside>
</section>

<script>
  document.querySelector<HTMLButtonElement>('[data-copy-booking-link]')?.addEventListener('click', async () => {
    const status = document.querySelector<HTMLElement>('[data-copy-booking-status]');
    try {
      await navigator.clipboard.writeText(window.location.href);
      if (status) status.textContent = 'Page address copied.';
    } catch {
      if (status) status.textContent = 'Use your browser address bar to copy this page address.';
    }
  });
  document.querySelector<HTMLButtonElement>('[data-refresh-booking-page]')?.addEventListener('click', () => window.location.reload());
</script>
