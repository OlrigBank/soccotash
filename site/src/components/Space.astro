---
import { render, type CollectionEntry } from 'astro:content';

interface Props {
  space: CollectionEntry<'spaces'>;
}

const { space } = Astro.props;
const { Content } = await render(space);
const primaryImage = space.data.image || space.data.gallery?.[0];

function pluralFact(value: number | undefined, singular: string, plural: string) {
  if (value === undefined || value <= 0) return null;
  return `${value} ${value === 1 ? singular : plural}`;
}

function spaceTypeLabel(value: string | undefined) {
  if (!value) return null;
  if (value.toLowerCase() === 'wc') return 'WC';
  return value.charAt(0).toUpperCase() + value.slice(1);
}

const floorLabels: Record<string, string> = {
  ground: 'Ground floor',
  first: 'First floor',
  'split-level': 'Split level',
  outdoor: 'Outdoor',
};

const bedFact = space.data.bedTypes.length
  ? space.data.bedTypes.join(', ')
  : pluralFact(space.data.beds, 'bed', 'beds');

const facts = [
  spaceTypeLabel(space.data.spaceType),
  space.data.floor ? floorLabels[space.data.floor] ?? space.data.floor : null,
  space.data.sleeps !== undefined ? `Sleeps ${space.data.sleeps}` : null,
  bedFact,
  pluralFact(space.data.bathrooms, 'bathroom', 'bathrooms'),
  pluralFact(space.data.toilets, 'toilet', 'toilets'),
  space.data.ensuite ? 'Ensuite' : null,
  space.data.shared ? 'May be shared' : null,
].filter(Boolean);
---

<article class="space-card">
  {primaryImage ? <img src={primaryImage} alt={space.data.title} loading="lazy" /> : null}
  <div class="space-card-content">
    <h3>{space.data.title}</h3>
    {space.data.summary ? <p>{space.data.summary}</p> : null}
    {facts.length ? <p class="space-facts">{facts.join(' · ')}</p> : null}

    {space.data.views.length ? (
      <div class="space-detail">
        <h4>Views</h4>
        <p>{space.data.views.join(' · ')}</p>
      </div>
    ) : null}

    {space.data.features.length ? (
      <div class="space-detail">
        <h4>Features</h4>
        <ul class="space-features">
          {space.data.features.map((feature) => <li>{feature}</li>)}
        </ul>
      </div>
    ) : null}

    {space.data.accessInformation ? (
      <div class="space-detail">
        <h4>Access</h4>
        <p>{space.data.accessInformation}</p>
      </div>
    ) : null}

    <div class="space-body">
      <Content />
    </div>
  </div>
</article>
