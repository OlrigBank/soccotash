# Used only when running Astro directly rather than through Docker Compose.
DATABASE_URL=postgresql://soccotash:password@localhost:5432/soccotash
DATABASE_SSL=false
AIRBNB_MAIN_HOUSE_ICAL_URLS=https://www.airbnb.com/calendar/ical/REPLACE.ics?s=REPLACE
AIRBNB_COTTAGE_ICAL_URLS=https://www.airbnb.com/calendar/ical/REPLACE.ics?s=REPLACE
CALENDAR_SYNC_TOKEN=replace-with-a-long-random-value
BOOKING_SERVICE_URL=http://localhost:4322

# Booking-offer email delivery. Choose smtp or resend.
EMAIL_PROVIDER=smtp
BOOKING_EMAIL_FROM="Olrig Bank <olrig.bank@gmail.com>"
BOOKING_EMAIL_REPLY_TO=olrig.bank@gmail.com
# Receives direct notifications when a customer accepts or declines an offer.
BOOKING_ADMIN_EMAIL=olrig.bank@gmail.com
# Optional comma-separated management copy recipients.
BOOKING_EMAIL_BCC=

# SMTP example for a Gmail account using an app password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=olrig.bank@gmail.com
SMTP_PASSWORD=replace-with-an-app-password
# Leave true in production. Set false only for a trusted local test server.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Alternative when EMAIL_PROVIDER=resend:
RESEND_API_KEY=

# Percentage deposit required after an offer is accepted.
BOOKING_DEPOSIT_PERCENT=25
